{
  "name": "devpulse-api",
  "version": "1.0.0",
  "description": "DevPulse - Internal Tech Issue & Feature Tracker API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
